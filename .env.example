# Database
# 5433 matches docker-compose's host mapping ("5433:5432" — avoids clashing
# with a locally installed Postgres). Inside containers the API uses db:5432.
DATABASE_URL=postgresql://goodjob:goodjob@localhost:5433/goodjob

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=dev-local-secret-do-not-use-in-production-a1b2c3d4e5
JWT_EXPIRES_IN=7d

# AI (Semantic Search)
GEMINI_API_KEY=your-gemini-key

# Media
MAX_VIDEO_DURATION_SECONDS=180
UPLOAD_DIR=./uploads

# App
PORT=3000
NODE_ENV=development

VITE_API_URL=http://localhost:3000

WEB_ORIGIN=
ADMIN_EMAILS=alice@goodjob.dev
